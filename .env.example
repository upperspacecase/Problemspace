# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/problemboard?retryWrites=true&w=majority

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Client SDK (public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Reddit Problem Finder Bot
BOT_SECRET=any-random-secret-string-here
ANTHROPIC_API_KEY=sk-ant-...

# Resend (transactional emails)
RESEND_API_KEY=re_...
RESEND_FROM=Problem Board <hello@problemboard.app>

# Internal API auth (used between server routes)
INTERNAL_API_SECRET=another-random-secret-string
